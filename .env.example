# Copy to .env and/or .env.local in your project root (do not commit secrets).

# --- @verndale/ai-commit (pnpm commit / ai-commit run)
OPENAI_API_KEY=

# Optional — default is gpt-4o-mini
# COMMIT_AI_MODEL=

# --- @verndale/ai-pr (pnpm open-pr) — GitHub PR create/update
# Use GH_TOKEN or GITHUB_TOKEN — PAT with repo scope
GH_TOKEN=

# PR_BASE_BRANCH=main
# PR_DRAFT=true
# PR_HEAD_BRANCH=   # optional; CI often sets this explicitly

# Optional AI summary for PR body (set PR_AI=true to enable)
# PR_AI=false
# PR_AI_ENDPOINT=
# PR_AI_API_KEY=
# PR_AI_MODEL=
